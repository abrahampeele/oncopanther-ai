// OncoPanther Base Quality Score recalibration Output Paths 
def OncoPantherBQSROutput() { 

OncoPantherWelcome()
log.info"""
                                                                              
\033[32m~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
\033[32m ✔ Available Cpus               =\033[37m ${ params.detectedCpus }
