/*
 * validation.config — OncoPanther-AI Publication Validation
 * ============================================================
 * Nextflow config for running GIAB benchmarks and runtime benchmarks.
 *
 * Usage (chr20 quick validation):
 *   nextflow run main.nf \
 *     --validation true \
 *     --tovarcall /home/crak/giab/inputs/vcf.csv \
 *     --reference /home/crak/giab/reference/chr20.fa \
 *     --outdir /home/crak/giab/results \
 *     -c paper/validation.config \
 *     -profile docker
 *
 * Usage (runtime benchmark):
 *   nextflow run main.nf \
 *     --benchmark true \
 *     --tovarcall /home/crak/giab/inputs/bam.csv \
 *     --reference /path/to/GRCh38.fa \
 *     --outdir /home/crak/giab/benchmark \
 *     -c paper/validation.config \
 *     -profile docker
 */

params {
    // ── GIAB Validation ──────────────────────────────────────────────────────
    validation          = false
    giab_samples        = ["HG002"]           // Add HG003, HG004 for full trio
    giab_truth_base     = "/home/crak/giab"   // Where truth VCFs were downloaded

    // ── Runtime Benchmark ────────────────────────────────────────────────────
    benchmark           = false
    benchmark_chrom     = "chr1"

    // ── Output ───────────────────────────────────────────────────────────────
    outdir              = "/home/crak/giab/results"
}

// Process resource labels for validation
process {
    withLabel: 'process_low' {
        cpus   = 2
        memory = '4 GB'
        time   = '2 h'
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '16 GB'
        time   = '6 h'
    }
    withLabel: 'process_high' {
        cpus   = 8
        memory = '32 GB'
        time   = '12 h'
    }
}
