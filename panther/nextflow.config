// nextflow.config file


// Auto-detect CPUs (inline, safe)

def availableCpus = {
    try {
        ['nproc'].execute().text.trim().toInteger()
    } catch (Exception e) {
        Runtime.runtime.availableProcessors()
    }
}.call()


// Parameters

params {
	detectedCpus    = availableCpus                 // Max detected CPUs
	mcpus           = null ?: Math.max(1, availableCpus - 2) // max CPUs for pipeline, leave 2 free
	pcpus 	        = null ?: Math.max(1, availableCpus - 2) // default CPUs per process

	outdir		= "outdir" 
	stepmode	= null  // Step mode for running modules
	fullmode	= null  // full mode [ fq to vcf ]
	input 		= null  // input for full mode
	bqsr		= null  // bqsr enable in full mode
	
	trimmomatic 	= false // Trimming with trimmomatic tool
	fastp		= false // Trimming with fastp tool
	bbduk		= false // Trimming with bbduk tool
	adapters	= null	// Path for adapter file
	caller          = null  // --caller deepvariant 
	modelType       = null  // model_type parameter required for deepvariant caller 
			
	reference	= null	// Reference file path
	
	rawreads	= null 	// Raw reads paths
	tobetrimmed 	= null	// Raw reads paths + trimmomatic parameters
	tobealigned 	= null 	// Trimmed read paths 
	bam		= null  // Bam files paths used for base recalibration 
	tovarcall	= null  // Bam files paths used for variant calling
	tofilter        = null  // Vcf file to be filtered
	// Filtering Parameters //
	QD              = 2.0   // Quality by Depth: variant confidence normalized by depth
	QUAL            = 30.0  // Overall variant quality score
	SOR             = 3.0   // Strand Odds Ratio: measures strand bias
	FSSNP           = 60.0  // Fisher Strand (SNPs): p-value for strand bias
	MQ              = 40.0  // RMS Mapping Quality of reads supporting the variant
	MQRankSum       = -12.5 // Z-score from Wilcoxon rank sum test of Alt vs Ref read mapping qualities
	ReadPosRankSumSNP  = -8.0 //  Z-score from Wilcoxon rank sum test of Alt vs Ref read position within reads (SNPs)
	
	FSINDEL         = 200.0 // Fisher Strand (INDELs): p-value for strand bias for indels
	ReadPosRankSumINDEL = -20.0 // Z-score from Wilcoxon rank sum test of Alt vs Ref read position within reads (INDELs)
 
	toannotate 	= null  // Vcf files paths used for annotation
	
	knownsite1	= null 	// knownsites file n°1
	knownsite2  	= null  // knownsites file n°1
	rsid            = null  // vcf file 
	
	aligner		= null  // Default to bwa -> bwamem2 [optional]
	
	generate	= null  // The default parameter generates csv, or to generate coverage of a target bed file while mapping 
	basedon		= null 	// First input csv to prepare CSVs based on it
	region		= null  // To extract specific region while variant calling
	bedtarget	= null  // Bed file
	keepinter  	= false // Keep intermediate BAM files derived from alignment  
	report		= false // Enables Metrics-bigwigs-html summary for Bam files 
	mindepth	= 0 	// Minimum depth in coverage bin plots
	saveImg 	= false // Save images( plots ) from bigwig files

	mode		= null  // The default (null) parameter generates vcf for all inputs : --mode cohort
	
	species    	= "homo_sapiens"  // Vep Cache specie
	assembly 	= "GRCh38"        // Species assembly
	cachetype 	= null            // Vep Cache type (null = default ensembl)
	cacheversion	= "114"           // VEP cache version
	cachedir  	= "/home/crak/.vep" // VEP cache dir (populated by setup_vep.sh)
	
		   
	oncopantherLogo 	= ".oncopanther.png" // OncoPanther logo
	metaPatients 	= null // Csv of Metadata of patiens +vcf paths
	metaYaml  	= null // Yaml file of Physician metadata + executions steps info

	// Pharmacogenomics (PGx) Parameters
	pgx             = false     // Enable PGx analysis in fullmode
	pgxVcf          = null      // CSV with VCF paths for PGx stepmode
	pgxRefGenome    = null      // GRCh38 reference FASTA for PharmCAT preprocessor
	pgxOutsideCalls = null      // TSV with outside calls (e.g., CYP2D6 from Stargazer)
	pgxSources      = "CPIC"   // Recommendation sources: CPIC, DPWG, FDA

	// CYP2D6 Star Allele Calling (Cyrius - Illumina)
	cyp2d6          = false     // Enable CYP2D6 structural variant calling via Cyrius
	pgxBam          = null      // CSV with patient_id and bamFile columns for CYP2D6 calling

	// ── ACMG/AMP Variant Interpretation (Richards et al. 2015) ──────────────
	// Reference: Genetics in Medicine 17:405-424
	// Criteria implemented: PVS1, PS1, PM1-2, PM4-5, PP2-3, PP5, BA1, BS1, BP1, BP4, BP7
	acmg            = true     // Enable ACMG/AMP variant classification (module 07.3)

	// Optional: ClinVar VCF for PS1/PP5 criteria (download from NCBI)
	// https://ftp.ncbi.nlm.nih.gov/pub/clinvar/vcf_GRCh38/clinvar.vcf.gz
	clinvar         = "/home/crak/clinvar/clinvar.vcf.gz"  // ClinVar VCF.gz (downloaded by setup_vep.sh)

	// Optional: SpliceAI delta score file for splice variant PVS1 upgrade
	// https://github.com/Illumina/SpliceAI
	spliceai        = null      // Path to SpliceAI SNV scores TSV (bgzipped + tabixed)

}

// Config Files 

    includeConfig 'conf/igenomes.config' 
    includeConfig 'conf/ivcf.config'
    includeConfig 'conf/test.config'
    includeConfig 'conf/exec.config'

// Pofiles

profiles  {  
    conda {
        conda.enabled           = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        channels                = ['conda-forge', 'bioconda', 'defaults']
    }
    mamba {
        conda.enabled           = true
        conda.useMamba          = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
    }
    docker {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        singularity.ociAutoPull = true
     // singularity.cacheDir    = "./work/singularity" 
        conda.enabled           = false
        docker.enabled          = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
    }
    apptainer {
        apptainer.enabled       = true
        apptainer.autoMounts    = true
        apptainer.ociAutoPull 	= true
     // apptainer.cacheDir    	= "./work/singularity" 
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
    }    
     wave {
        singularity.enabled     = true
        singularity.autoMounts  = true
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container' 
    }
    podman {
        podman.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        docker.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
    }
    shifter {
        shifter.enabled         = true
        conda.enabled           = false
        singularity.enabled     = false
        docker.enabled          = false
        podman.enabled          = false
        charliecloud.enabled    = false
    }
    charliecloud {
        charliecloud.enabled    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
    }
}

// Pipeline Reporting 

def date = new Date().format("HH-mm-ss-dd-MM-yyyy")

report {
    enabled     = true
    overwrite   = true
    file        = "${params.outdir}/RunReports/${date}_my_report.html"
}

trace {
    enabled     = true
    overwrite   = true
    file        = "${params.outdir}/RunReports/${date}_my_trace.txt"
}

timeline {
    enabled     = true
    overwrite   = true
    file        = "${params.outdir}/RunReports/${date}_my_timeline.html"
}

dag {
    enabled     = true
    overwrite   = true
    file        = "${params.outdir}/RunReports/${date}_my_pipeline_dag.dot"
}

// Pipeline Info

manifest {
    name            = 'SecuAI/OncoPanther-AI'
    author          = """Abraham Peele, Kesava Mullati, Vuyyuru Kesavi Hima Bindhu, Rayidi Sri Sai Chinmai"""
    homePage        = 'https://github.com/SecuAI/OncoPanther-AI'
    description     = """AI-Powered Nextflow Pipeline for Variant Calling, Pharmacogenomics, and Precision Oncology Decision Support"""
    defaultBranch   = 'main'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=24.04.2'
    version         = '1.0.0'
    doi             = '---'
}
