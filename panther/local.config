// Local override config — sets environment variables for all Nextflow processes
// Fixes JAVA_HOME and PYTHONPATH for PharmCAT tools running without a container

env {
    JAVA_HOME    = '/usr/lib/jvm/java-17-openjdk-amd64'
    PYTHONPATH   = '/mnt/c/Users/drkat/OneDrive/Desktop/oncopanther-pgx/oncopanther-pgx/panther'
    // Don't hardcode PATH — let conda profile manage it per-process so each
    // process finds its own conda-env tools (e.g. gatk, bwa, pharmcat).
    // Java + Cyrius are prepended via beforeScript below without clobbering it.
}

// Prepend Java and Cyrius to whatever PATH each conda env sets
process {
    beforeScript = 'export PATH="/usr/lib/jvm/java-17-openjdk-amd64/bin:/home/crak/tools/Cyrius:$PATH"'
}

// Use local WSL filesystem for conda env cache (avoids slow OneDrive/NTFS I/O)
conda.cacheDir = '/home/crak/.nf-conda-cache'
